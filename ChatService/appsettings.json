{
    "Logging": {
        "LogLevel": {
            "Default": "Warning"
        }
    },
    "Spring": {
        "Application": {
            "Name": "ChatService"
        }
    },
    "Eureka": {
        "Client": {
            "ServiceUrl": "http://localhost:8761/eureka/",
            "ShouldRegisterWithEureka": true,
            "ShouldFetchRegistry": true
        },
        "Instance": {
            "AppName": "chatservice",
            "Port": 4099,
            "HostName": "localhost"
        }
    },
    "AppSettings": {
        "Secret": "THIS_IS_A_RANDOM_SECRET_...",
        "AllowedChatOrigins": [
            "http://localhost:8080",
            "http://host.docker.internal:8080",
            "http://localhost:5081"
        ]
    }
}